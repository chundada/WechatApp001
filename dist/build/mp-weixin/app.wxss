page{background-color:#f2f2f7;font-family:-apple-system,BlinkMacSystemFont,SF Pro Display,Helvetica Neue,Arial,sans-serif;font-size:28rpx;color:#1d1d1f;box-sizing:border-box;min-height:100vh}.container{padding:24rpx}.card{background:#fff;border-radius:20rpx;padding:32rpx;margin-bottom:20rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.04)}.btn-primary{background:#007aff;color:#fff;border:none;border-radius:40rpx;padding:24rpx 48rpx;font-size:28rpx;font-weight:500}.btn-primary:active{opacity:.8;transform:scale(.98)}.btn-secondary{background:#f2f2f7;color:#1d1d1f;border:none;border-radius:40rpx;padding:24rpx 48rpx;font-size:28rpx;font-weight:500}.btn-secondary:active{background:#e5e5ea;transform:scale(.98)}.btn-tertiary{background:transparent;color:#007aff;border:none;border-radius:40rpx;padding:24rpx 48rpx;font-size:28rpx;font-weight:500}.btn-tertiary:active{background:rgba(0,122,255,.06)}.flex{display:flex}.flex-col{flex-direction:column}.items-center{align-items:center}.justify-center{justify-content:center}.justify-between{justify-content:space-between}.text-center{text-align:center}.text-primary-color{color:#007aff}.text-success{color:#34c759}.text-warning{color:#ff9500}.text-error{color:#ff3b30}.text-muted{color:#aeaeb2}.mt-2{margin-top:16rpx}.mt-4{margin-top:32rpx}.mb-2{margin-bottom:16rpx}.mb-4{margin-bottom:32rpx}.mr-2{margin-right:16rpx}.ml-2{margin-left:16rpx}.w-full{width:100%}
page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}