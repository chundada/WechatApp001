page {
  background-color: #1C1C1E;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
  color: #FFFFFF;
  box-sizing: border-box;
  min-height: 100vh;
}
.container {
  padding: 24rpx;
}
.card {
  background: #2C2C2E;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #48484A;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}
.btn-primary {
  background: #007AFF;
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  padding: 28rpx 56rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 16rpx rgba(0, 122, 255, 0.3), inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}
.btn-primary:active {
  opacity: 0.8;
  transform: scale(0.98);
}
.btn-secondary {
  background: #3A3A3C;
  color: #FFFFFF;
  border: none;
  border-radius: 44rpx;
  padding: 28rpx 56rpx;
  font-size: 30rpx;
  font-weight: 500;
}
.btn-secondary:active {
  background: #48484A;
  transform: scale(0.98);
}
.btn-tertiary {
  background: transparent;
  color: #007AFF;
  border: none;
  border-radius: 44rpx;
  padding: 28rpx 56rpx;
  font-size: 30rpx;
  font-weight: 500;
}
.btn-tertiary:active {
  background: rgba(0, 122, 255, 0.1);
}
.flex {
  display: flex;
}
.flex-col {
  flex-direction: column;
}
.items-center {
  align-items: center;
}
.justify-center {
  justify-content: center;
}
.justify-between {
  justify-content: space-between;
}
.text-center {
  text-align: center;
}
.text-primary-color {
  color: #007AFF;
}
.text-success {
  color: #34C759;
}
.text-warning {
  color: #FF9500;
}
.text-error {
  color: #FF3B30;
}
.text-muted {
  color: #AEAEB2;
}
.mt-2 {
  margin-top: 16rpx;
}
.mt-4 {
  margin-top: 32rpx;
}
.mb-2 {
  margin-bottom: 16rpx;
}
.mb-4 {
  margin-bottom: 32rpx;
}
.mr-2 {
  margin-right: 16rpx;
}
.ml-2 {
  margin-left: 16rpx;
}
.w-full {
  width: 100%;
}
.glass-effect {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}
.shimmer {
  background: linear-gradient(90deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.05) 50%, rgba(255, 255, 255, 0) 100%);
  background-size: 200% 100%;
  animation: shimmer 2s infinite;
}
@keyframes shimmer {
0% {
    background-position: -200% 0;
}
100% {
    background-position: 200% 0;
}
}page{--status-bar-height:25px;--top-window-height:0px;--window-top:0px;--window-bottom:0px;--window-left:0px;--window-right:0px;--window-magin:0px}[data-c-h="true"]{display: none !important;}