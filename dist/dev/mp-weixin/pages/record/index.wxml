<view class="page data-v-e218755a"><view class="add-section data-v-e218755a"><view class="add-card card data-v-e218755a"><text class="add-title data-v-e218755a">添加体重记录</text><view class="input-group data-v-e218755a"><view class="weight-input-wrapper data-v-e218755a"><input class="weight-input data-v-e218755a" type="digit" placeholder="请输入体重" value="{{a}}" bindinput="{{b}}"/><text class="weight-unit data-v-e218755a">kg</text></view><input class="note-input data-v-e218755a" placeholder="今日备注（可选）" value="{{c}}" bindinput="{{d}}"/></view><button class="submit-btn btn-primary data-v-e218755a" bindtap="{{e}}">保存记录</button></view></view><view class="history-section data-v-e218755a"><view class="section-header data-v-e218755a"><text class="section-title data-v-e218755a">历史记录</text><text class="record-count data-v-e218755a">共 {{f}} 条</text></view><view class="record-list data-v-e218755a"><view wx:for="{{g}}" wx:for-item="record" wx:key="h" class="record-item card data-v-e218755a"><view class="record-header data-v-e218755a"><text class="record-date data-v-e218755a">{{record.a}}</text><text class="record-weight data-v-e218755a">{{record.b}}kg</text></view><text wx:if="{{record.c}}" class="record-note data-v-e218755a">{{record.d}}</text><view wx:if="{{record.e}}" class="record-trend data-v-e218755a"><text class="{{['trend-text', 'data-v-e218755a', record.g]}}">{{record.f}}</text></view></view></view><view wx:if="{{h}}" class="empty-state data-v-e218755a"><text class="empty-icon data-v-e218755a">📝</text><text class="empty-text data-v-e218755a">还没有体重记录</text><text class="empty-hint data-v-e218755a">开始记录你的减肥之旅吧</text></view></view></view>